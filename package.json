{
  "name": "ai-radar-web",
  "version": "0.1.0",
  "private": true,
  "description": "Bilingual AI industry radar website skeleton.",
  "scripts": {
    "dev": "next dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/smoke-test.ts && tsx scripts/static-local-query.test.ts && tsx scripts/run-resumable-activation.test.ts && tsx scripts/sitemap-fetcher.test.ts && tsx scripts/html-fetcher.test.ts && tsx scripts/event-clustering.test.ts && tsx scripts/cross-family-audit.test.ts && tsx scripts/cluster-events-persistence.test.ts && tsx scripts/supabase-radar-read.test.ts",
    "import:sources": "tsx scripts/import-ai-learning-resources.ts",
    "ingest:sources": "tsx scripts/ingest-sources.ts",
    "ingest:sources:dry-run": "tsx scripts/ingest-sources.ts --dry-run",
    "understand:items": "tsx scripts/understand-items.ts",
    "understand:items:mock": "tsx scripts/understand-items.ts --mode mock",
    "understand:items:live": "tsx scripts/understand-items.ts --mode live",
    "data:activate:mock": "tsx scripts/activate-radar-data.ts --limit 10 --max-items-per-source 5",
    "data:activate:live": "tsx scripts/activate-radar-data.ts --limit 10 --max-items-per-source 5 --live",
    "data:activate:persist": "tsx scripts/activate-radar-data.ts --limit 10 --max-items-per-source 5 --persist",
    "data:activate:live:persist": "tsx scripts/activate-radar-data.ts --limit 10 --max-items-per-source 5 --live --persist",
    "data:activate:resumable:mock": "tsx scripts/run-resumable-activation.ts --mode mock",
    "data:activate:resumable:live": "tsx scripts/run-resumable-activation.ts --mode live",
    "data:activate:resumable:live:persist": "tsx scripts/run-resumable-activation.ts --mode live --persist",
    "data:activate:resumable:resume": "tsx scripts/run-resumable-activation.ts --resume",
    "data:activate:resumable:status": "tsx scripts/run-resumable-activation.ts --status",
    "data:status": "tsx scripts/activate-radar-data.ts --report-only",
    "ops:dry-run": "tsx scripts/run-operating-loop.ts --mode dry-run",
    "ops:refresh:live": "tsx scripts/run-operating-loop.ts --mode refresh-data --live",
    "ops:refresh:live:persist": "tsx scripts/run-operating-loop.ts --mode refresh-data --live --persist",
    "ops:summary": "tsx scripts/write-ops-summary.ts",
    "scheduled:hourly:dry-run": "tsx scripts/run-scheduled-radar-job.ts --mode hourly-dry-run",
    "supabase:import:sources": "tsx scripts/supabase-import-sources.ts",
    "supabase:persist:ingestion": "tsx scripts/supabase-persist-ingestion.ts",
    "supabase:persist:understanding": "tsx scripts/supabase-persist-understanding.ts",
    "supabase:public-contract": "tsx scripts/check-supabase-public-contract.ts",
    "source-health:check": "tsx scripts/check-source-health.ts",
    "source-health:dry-run": "tsx scripts/check-source-health.ts --dry-run",
    "data:completeness:audit": "tsx scripts/audit-data-completeness.ts",
    "events:cluster": "tsx scripts/cluster-events.ts",
    "events:audit-cross-family": "tsx scripts/audit-cross-family-events.ts",
    "auth:bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "validate:data": "tsx scripts/validate-schemas.ts",
    "sensitive:scan": "tsx scripts/sensitive-scan.ts",
    "external:learnprompt:diff": "tsx scripts/compare-learnprompt-radar.ts",
    "cloudflare:snapshot": "tsx scripts/export-public-snapshot.ts",
    "cloudflare:build": "npm run cloudflare:snapshot && tsx scripts/build-cloudflare-public-site.ts",
    "check:deployment": "npm run lint && npm run typecheck && npm run validate:data && npm run sensitive:scan && npm run supabase:public-contract && npm run build && npm run test",
    "build": "next build && npm run cloudflare:build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.86.0",
    "next": "^15.5.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "license": "MIT"
}
