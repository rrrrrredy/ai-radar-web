{
  "name": "ai-radar-web",
  "version": "0.1.0",
  "private": true,
  "description": "Bilingual AI industry radar website skeleton.",
  "scripts": {
    "dev": "next dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "import:sources": "tsx scripts/import-ai-learning-resources.ts",
    "ingest:sources": "tsx scripts/ingest-sources.ts",
    "ingest:sources:dry-run": "tsx scripts/ingest-sources.ts --dry-run",
    "understand:items": "tsx scripts/understand-items.ts",
    "understand:items:mock": "tsx scripts/understand-items.ts --mode mock",
    "understand:items:live": "tsx scripts/understand-items.ts --mode live",
    "data:activate:mock": "tsx scripts/activate-radar-data.ts --limit 10 --max-items-per-source 5",
    "data:activate:live": "tsx scripts/activate-radar-data.ts --limit 10 --max-items-per-source 5 --live",
    "data:activate:persist": "tsx scripts/activate-radar-data.ts --limit 10 --max-items-per-source 5 --persist",
    "data:activate:live:persist": "tsx scripts/activate-radar-data.ts --limit 10 --max-items-per-source 5 --live --persist",
    "data:status": "tsx scripts/activate-radar-data.ts --report-only",
    "scheduled:hourly:dry-run": "tsx scripts/run-scheduled-radar-job.ts --mode hourly-dry-run",
    "scheduled:daily:dry-run": "tsx scripts/run-scheduled-radar-job.ts --mode daily-report-seed",
    "scheduled:weekly:dry-run": "tsx scripts/run-scheduled-radar-job.ts --mode weekly-report-seed",
    "supabase:import:sources": "tsx scripts/supabase-import-sources.ts",
    "supabase:persist:ingestion": "tsx scripts/supabase-persist-ingestion.ts",
    "supabase:persist:understanding": "tsx scripts/supabase-persist-understanding.ts",
    "source-health:check": "tsx scripts/check-source-health.ts",
    "source-health:dry-run": "tsx scripts/check-source-health.ts --dry-run",
    "auth:bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "validate:data": "tsx scripts/validate-schemas.ts",
    "sensitive:scan": "tsx scripts/sensitive-scan.ts",
    "check:deployment": "npm run lint && npm run typecheck && npm run validate:data && npm run sensitive:scan && npm run build",
    "build": "next build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.86.0",
    "next": "^15.5.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "license": "MIT"
}
