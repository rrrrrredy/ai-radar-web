{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ai-radar-web/entity.schema.json",
  "title": "Entity",
  "type": "object",
  "required": ["id", "type", "name"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["company", "person", "model", "product", "paper", "project"]
    },
    "name": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string"
    },
    "homepage_url": {
      "type": "string",
      "format": "uri"
    },
    "metadata": {
      "type": "object"
    }
  }
}

